/**
 * Execute an SDK method by name with parameters
 */
export async function executeSdkMethod(
  methodName: string, 
  params: any, 
  accessToken: string, 
  basePath: string
): Promise<ApiResponse<any>> {
  const sdkFunction = sdkFunctions[methodName];
  
  if (!sdkFunction) {
    return {
      data: null,
      status: 404,
      statusText: `SDK method '${methodName}' not found`,
      headers: {}
    };
  }

  const config = createSdkConfiguration(accessToken, basePath);
  return await sdkFunction(params, config);
}